---
interface Props {
  class?: string;
  withWordmark?: boolean;
}
const { class: className, withWordmark = false } = Astro.props;
---

{
  withWordmark ? (
    <span class={`inline-flex items-center gap-2.5 ${className ?? ""}`}>
      <svg
        viewBox="0 0 120 40"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        aria-hidden="true"
        class="h-7 w-auto"
      >
        <circle cx="60" cy="20" r="13" stroke="currentColor" stroke-width="1" stroke-opacity="0.35" />
        <circle cx="60" cy="20" r="17" stroke="currentColor" stroke-width="1" stroke-opacity="0.2" />
        <circle cx="20" cy="20" r="8" fill="currentColor" />
        <circle cx="60" cy="20" r="8" stroke="currentColor" stroke-width="2.25" />
        <circle cx="100" cy="20" r="8" fill="currentColor" />
      </svg>
      <span class="text-base font-semibold tracking-tight"><span class="text-brand dark:text-brand-light">ai</span>zuchi</span>
    </span>
  ) : (
    <svg
      viewBox="0 0 120 40"
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      role="img"
      aria-label="Aizuchi"
      class={className}
    >
      <circle cx="60" cy="20" r="13" stroke="currentColor" stroke-width="1" stroke-opacity="0.35" />
      <circle cx="60" cy="20" r="17" stroke="currentColor" stroke-width="1" stroke-opacity="0.2" />
      <circle cx="20" cy="20" r="8" fill="currentColor" />
      <circle cx="60" cy="20" r="8" stroke="currentColor" stroke-width="2.25" />
      <circle cx="100" cy="20" r="8" fill="currentColor" />
    </svg>
  )
}
