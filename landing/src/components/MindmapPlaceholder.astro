    <defs>
      <linearGradient id="nodeGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="rgb(255 255 255)" />
        <stop offset="100%" stop-color="rgb(248 250 252)" />
      </linearGradient>
      <linearGradient id="centerGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="rgb(99 102 241)" />
        <stop offset="100%" stop-color="rgb(79 70 229)" />
      </linearGradient>
    </defs>

    <g stroke="currentColor" stroke-opacity="0.18" stroke-width="1.5" fill="none" stroke-linecap="round">
      <path d="M 400 230 C 320 230, 250 150, 180 130" />
      <path d="M 400 230 C 320 230, 250 230, 180 230" />
      <path d="M 400 230 C 320 230, 250 310, 180 330" />
      <path d="M 400 230 C 480 230, 550 150, 620 130" />
      <path d="M 400 230 C 480 230, 550 230, 620 230" />
      <path d="M 400 230 C 480 230, 550 310, 620 330" />
    </g>

    <g class="text-slate-700 dark:text-slate-200" fill="currentColor" font-family="ui-sans-serif, system-ui, sans-serif">
      <g>
        <rect x="120" y="108" width="120" height="44" rx="10" fill="url(#nodeGrad)" stroke="currentColor" stroke-opacity="0.12" stroke-width="1" class="dark:fill-slate-900/80 dark:stroke-white/10" />
        <text x="180" y="135" text-anchor="middle" font-size="13" font-weight="500">Yesterday</text>
      </g>
      <g>
        <rect x="120" y="208" width="120" height="44" rx="10" fill="url(#nodeGrad)" stroke="currentColor" stroke-opacity="0.12" stroke-width="1" class="dark:fill-slate-900/80 dark:stroke-white/10" />
        <text x="180" y="235" text-anchor="middle" font-size="13" font-weight="500">Today</text>
      </g>
      <g>
        <rect x="120" y="308" width="120" height="44" rx="10" fill="url(#nodeGrad)" stroke="currentColor" stroke-opacity="0.12" stroke-width="1" class="dark:fill-slate-900/80 dark:stroke-white/10" />
        <text x="180" y="335" text-anchor="middle" font-size="13" font-weight="500">Blockers</text>
