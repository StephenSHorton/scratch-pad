      <circle cx="400" cy="230" r="58" fill="none" stroke="rgb(99 102 241)" stroke-opacity="0.25" stroke-width="1" />
      <circle cx="400" cy="230" r="72" fill="none" stroke="rgb(99 102 241)" stroke-opacity="0.12" stroke-width="1" />
      <text x="400" y="226" text-anchor="middle" fill="white" font-size="12" font-weight="600" font-family="ui-sans-serif, system-ui, sans-serif">Standup</text>
      <text x="400" y="244" text-anchor="middle" fill="white" fill-opacity="0.7" font-size="10" font-family="ui-sans-serif, system-ui, sans-serif">Tue · 9:30am</text>
    </g>

    <g class="text-slate-500 dark:text-slate-400" fill="currentColor" font-family="ui-sans-serif, system-ui, sans-serif">
      <text x="40" y="420" font-size="11" font-style="italic">"&hellip; merged the rename PR yesterday, MCP server is renamed too"</text>
