        <text x="640" y="135" text-anchor="middle" font-size="13" font-weight="500">Shipped AIZ-26</text>
      </g>
      <g>
        <rect x="560" y="208" width="160" height="44" rx="10" fill="url(#nodeGrad)" stroke="currentColor" stroke-opacity="0.12" stroke-width="1" class="dark:fill-slate-900/80 dark:stroke-white/10" />
        <text x="640" y="235" text-anchor="middle" font-size="13" font-weight="500">Landing page WIP</text>
