      <g>
        <rect x="560" y="308" width="160" height="44" rx="10" fill="url(#nodeGrad)" stroke="currentColor" stroke-opacity="0.12" stroke-width="1" class="dark:fill-slate-900/80 dark:stroke-white/10" />
        <text x="640" y="335" text-anchor="middle" font-size="13" font-weight="500">DNS for aizuchi.tools</text>
