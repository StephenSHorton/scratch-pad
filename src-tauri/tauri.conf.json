{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Scratch Pad",
  "version": "0.9.1",
  "identifier": "com.scratchpad.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "externalBin": [
      "binaries/scratch-pad-mcp"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJFMkMyMzhEMzk5NUI4ODkKUldTSnVKVTVqU01zdmdvb0k5RVpFb0lEUWhlVEZoZ1E2RHhVaEQzTUtzdDNKcXB5UEwrOWF6MUUK",
      "endpoints": [
        "https://github.com/StephenSHorton/scratch-pad/releases/latest/download/latest.json"
      ]
    }
  }
}
